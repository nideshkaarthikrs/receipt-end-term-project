# Firebase web app credentials.
# Copy this file to `.env` and fill in the values from your Firebase console:
#   Firebase console → Project settings → Your apps → Web app → SDK setup & config.
#
# None of these are secrets in the traditional sense (they are shipped to the browser),
# but keeping them out of source control keeps the repo portable and prevents accidental
# misuse of a project's quota by forks. Trust is enforced by Firestore Security Rules,
# not by hiding these values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
